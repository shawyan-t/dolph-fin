{
  "name": "dolph",
  "version": "0.1.2",
  "private": true,
  "description": "AI-powered SEC filing analyzer",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter @shawyan/shared build && pnpm --filter @shawyan/bootup build && pnpm --filter @shawyan/mcp-sec-server build && pnpm --filter @shawyan/mcp-financials-server build && pnpm --filter dolph-fin build && pnpm --filter @shawyan/web build",
    "bootup": "pnpm --filter bootup start",
    "analyze": "pnpm --filter agent start",
    "start": "pnpm --filter agent start",
    "test": "pnpm -r --if-present test",
    "release:pack-cli": "./scripts/publish-cli.sh --dry-run --skip-install",
    "release:publish-cli": "./scripts/publish-cli.sh --skip-install"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["puppeteer"]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67"
}
