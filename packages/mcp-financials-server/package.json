{
  "name": "@filinglens/mcp-financials-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools/*": {
      "import": "./dist/tools/*",
      "types": "./dist/tools/*"
    },
    "./xbrl/*": {
      "import": "./dist/xbrl/*",
      "types": "./dist/xbrl/*"
    }
  },
  "bin": {
    "filinglens-financials-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@filinglens/shared": "workspace:*",
    "@filinglens/mcp-sec-server": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
