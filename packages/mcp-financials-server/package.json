{
  "name": "@shawyan/mcp-financials-server",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools/*": {
      "import": "./dist/tools/*",
      "types": "./dist/tools/*"
    },
    "./xbrl/*": {
      "import": "./dist/xbrl/*",
      "types": "./dist/xbrl/*"
    }
  },
  "bin": {
    "dolph-financials-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/math/ratios.test.ts"
  },
  "dependencies": {
    "@shawyan/shared": "^0.1.3",
    "@shawyan/mcp-sec-server": "^0.1.3",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
