{
  "name": "@shawyan/agent",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pipeline": {
      "import": "./dist/pipeline.js",
      "types": "./dist/pipeline.d.ts"
    },
    "./llm/provider": {
      "import": "./dist/llm/provider.js",
      "types": "./dist/llm/provider.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*"
    }
  },
  "bin": {
    "dolph": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "start": "tsx src/cli.ts",
    "start:headless": "tsx src/index.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/analyzer.test.ts src/deterministic-qa.test.ts src/report-integrity.test.ts src/report-governance.test.ts src/exporter-period-banner.test.ts"
  },
  "dependencies": {
    "@shawyan/bootup": "^0.1.3",
    "@shawyan/mcp-financials-server": "^0.1.3",
    "@shawyan/mcp-sec-server": "^0.1.3",
    "@shawyan/shared": "^0.1.3",
    "@inquirer/prompts": "^7.0.0",
    "dotenv": "^16.4.0",

    "marked": "^15.0.0",
    "openai": "^4.80.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
