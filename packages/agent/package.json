{
  "name": "@filinglens/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pipeline": {
      "import": "./dist/pipeline.js",
      "types": "./dist/pipeline.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@filinglens/shared": "workspace:*",
    "@filinglens/mcp-sec-server": "workspace:*",
    "@filinglens/mcp-financials-server": "workspace:*",
    "openai": "^4.80.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
