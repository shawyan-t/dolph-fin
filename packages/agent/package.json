{
  "name": "@dolph/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pipeline": {
      "import": "./dist/pipeline.js",
      "types": "./dist/pipeline.d.ts"
    },
    "./llm/provider": {
      "import": "./dist/llm/provider.js",
      "types": "./dist/llm/provider.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*"
    }
  },
  "bin": {
    "dolph": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "start:headless": "tsx src/index.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/validator.test.ts src/dcf-builder.test.ts"
  },
  "dependencies": {
    "@dolph/bootup": "workspace:*",
    "@dolph/mcp-financials-server": "workspace:*",
    "@dolph/mcp-sec-server": "workspace:*",
    "@dolph/shared": "workspace:*",
    "@inquirer/prompts": "^7.0.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "marked": "^15.0.0",
    "openai": "^4.80.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
