# LLM Provider Configuration
# Supported: openai (recommended, ~$0.003/analysis), gemini (free tier), groq (free tier)
FILINGLENS_LLM_PROVIDER=openai
FILINGLENS_LLM_MODEL=gpt-4o-mini

# API Keys (only needed for your chosen provider)
FILINGLENS_OPENAI_API_KEY=
FILINGLENS_GEMINI_API_KEY=
FILINGLENS_GROQ_API_KEY=

# SEC EDGAR Configuration (required)
# SEC requires a User-Agent with company name and email
FILINGLENS_SEC_USER_AGENT="FilingLens contact@youremail.com"

# Cache Configuration
FILINGLENS_CACHE_DIR=~/.filinglens/cache

# Agent Configuration
FILINGLENS_MAX_RETRIES=2
FILINGLENS_MAX_VALIDATION_LOOPS=2
