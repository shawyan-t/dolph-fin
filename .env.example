# LLM Provider Configuration
# Supported: openai (recommended, ~$0.003/analysis), gemini (free tier), groq (free tier)
DOLPH_LLM_PROVIDER=openai
DOLPH_LLM_MODEL=gpt-4o-mini

# API Keys (only needed for your chosen provider)
DOLPH_OPENAI_API_KEY=
DOLPH_GEMINI_API_KEY=
DOLPH_GROQ_API_KEY=

# SEC EDGAR Configuration (required)
# SEC requires a User-Agent with company name and email
DOLPH_SEC_USER_AGENT="Dolph contact@youremail.com"

# Cache Configuration
DOLPH_CACHE_DIR=~/.dolph/cache

# Agent Configuration
DOLPH_MAX_RETRIES=2
DOLPH_MAX_VALIDATION_LOOPS=2
